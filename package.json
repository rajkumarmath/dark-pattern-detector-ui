{
  "name": "dark-pattern-detector-frontend",
  "version": "1.0.0",
  "description": "Modern UI for Dark Pattern Detection API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --watch",
    "dev:all": "concurrently \"npm run build:css\" \"npm run dev\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "form-data": "^4.0.5",
    "helmet": "^7.2.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
